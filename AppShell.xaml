<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Parcial2_Peliculas.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Parcial2_Peliculas"
    xmlns:views="clr-namespace:Parcial2_Peliculas.Views"
    Title="CineApp"
    Shell.BackgroundColor="#1a1a2e"
    Shell.ForegroundColor="#e94560"
    Shell.TitleColor="#e94560"
    Shell.UnselectedColor="#5c5c7a"
    Shell.TabBarBackgroundColor="#16213e"
    Shell.TabBarForegroundColor="#e94560"
    Shell.TabBarUnselectedColor="#5c5c7a"
    Shell.NavBarIsVisible="False">

    <TabBar>
        <ShellContent Title="Home"
                      Icon="home_icon.png"
                      ContentTemplate="{DataTemplate local:MainPage}"
                      Route="MainPage"/>

        <ShellContent Title="Buscar"
                      Icon="search_icon.png"
                      ContentTemplate="{DataTemplate views:BuscadorPage}"
                      Route="BuscadorPage"/>

        <ShellContent Title="Favoritos"
                      Icon="fav_icon.png"
                      ContentTemplate="{DataTemplate views:FavoritosPage}"
                      Route="FavoritosPage"/>
    </TabBar>

</Shell>
