<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Parcial2_Peliculas.Views.FavoritosPage"
             xmlns:vm="clr-namespace:Parcial2_Peliculas.ViewModels"
             BackgroundColor="#1a1a2e">

    <ContentPage.BindingContext>
        <vm:FavoritosViewModel/>
    </ContentPage.BindingContext>

    <Grid Padding="16" RowDefinitions="Auto,*" RowSpacing="12">

        <!-- Header -->
        <Label Grid.Row="0"
               Text="Mis Favoritos"
               FontSize="26"
               FontFamily="Minecraft"
               TextColor="#e94560"
               HorizontalOptions="Center"
               Padding="0,10,0,0"/>

        <!-- Favorites List -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Favoritos}"
                        SelectionMode="Single"
                        SelectedItem="{Binding PeliculaSeleccionada}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Eliminar"
                                           BackgroundColor="#e94560"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FavoritosViewModel}}, Path=EliminarCommand}"
                                           CommandParameter="{Binding .}"/>
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border Margin="0,6"
                                BackgroundColor="#16213e"
                                StrokeShape="RoundRectangle 14"
                                Stroke="#0f3460"
                                StrokeThickness="0.5"
                                Padding="12">
                            <Grid ColumnDefinitions="90,*" ColumnSpacing="14">
                                <Border Grid.Column="0"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="0"
                                        HeightRequest="135"
                                        WidthRequest="90">
                                    <Image Source="{Binding PosterUrl}" Aspect="AspectFill"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                    <Label Text="{Binding Title}" FontSize="17" FontAttributes="Bold"
                                           TextColor="White" LineBreakMode="TailTruncation" MaxLines="2"/>
                                    <Label Text="{Binding ReleaseDate, StringFormat='Estreno: {0}'}"
                                           FontSize="13" TextColor="#8d8d9b"/>
                                    <HorizontalStackLayout Spacing="6">
                                        <Border BackgroundColor="#e94560" StrokeShape="RoundRectangle 8"
                                                StrokeThickness="0" Padding="8,4" HeightRequest="28">
                                            <Label Text="{Binding VoteAverage, StringFormat='{0:F1}/10'}"
                                                   FontSize="12" TextColor="White" FontAttributes="Bold"
                                                   VerticalOptions="Center"/>
                                        </Border>
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Overview}" FontSize="12" TextColor="#6b6b80"
                                           LineBreakMode="TailTruncation" MaxLines="2"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="30" Spacing="12" VerticalOptions="Center">
                    <Label Text="Aun no tienes favoritos"
                           FontSize="18" HorizontalOptions="Center" TextColor="#5c5c7a"
                           FontFamily="Minecraft"/>
                    <Label Text="Manten presionada una pelicula para agregarla"
                           FontSize="13" HorizontalOptions="Center" TextColor="#3d3d56"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

        </CollectionView>

    </Grid>
</ContentPage>
